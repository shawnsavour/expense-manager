# Deployed Google Apps Script Web App URL
NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Set to /<repo-name> when hosting on GitHub Pages under a subdirectory
# Leave empty when hosting at the root domain
NEXT_PUBLIC_BASE_PATH=

# Google Spreadsheet ID (from the sheet URL)
NEXT_PUBLIC_SPREADSHEET_ID=YOUR_SPREADSHEET_ID

# Set to "false" to read directly from the public Google Sheet (no Apps Script needed).
# When "false", write operations (add expense, mark paid) are disabled.
# When "true" or unset, all calls go through Apps Script.
NEXT_PUBLIC_APPSCRIPT_ENABLED=true
